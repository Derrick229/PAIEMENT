# Récupère ces clés sur https://app.kkiapay.me/dashboard (mode Sandbox activé)
KKIAPAY_PUBLIC_KEY=ta_clef_publique_sandbox
KKIAPAY_PRIVATE_KEY=ta_clef_privee_sandbox
KKIAPAY_SECRET_KEY=ta_clef_secrete_sandbox
KKIAPAY_SANDBOX=true

PORT=3000

# Mot de passe pour accéder à la page admin (/admin)
ADMIN_PASSWORD=change-moi

# Chaîne aléatoire pour sécuriser les sessions (texte long et unique, au hasard)
SESSION_SECRET=change-moi-aussi-une-longue-chaine-aleatoire

# Connexion à la base de données Supabase (Settings > Database > Connection string > URI)
DATABASE_URL=postgresql://postgres:MOT_DE_PASSE@db.xxxxx.supabase.co:5432/postgres

# Clé partagée pour les futurs appels de l'ESP32 (capteur de niveau, confirmation de livraison)
ESP32_API_KEY=choisis-une-cle-secrete-pour-esp32

# Envoi d'email (reçu client). Exemple avec Gmail :
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tonadresse@gmail.com
# SMTP_PASS=le-mot-de-passe-application-genere-par-google
# SMTP_FROM=tonadresse@gmail.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
